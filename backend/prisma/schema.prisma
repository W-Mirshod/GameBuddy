generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  telegramId        String    @unique
  username          String?
  firstName         String
  steamId64         String?   @unique
  steamId32         String?
  steamUsername     String?
  steamAvatar       String?
  preferredGame     String?
  language          String?
  activeHours       String?
  lookingFor        String?
  isAdmin           Boolean   @default(false)
  isReferee         Boolean   @default(false)
  teamId            Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  team              Team?     @relation(fields: [teamId], references: [id])
  ownedTeam         Team?     @relation("TeamOwner")
  cs2Stats          CS2Stats?
  dota2Stats        Dota2Stats?
  registrations     Registration[]
  escrows           Escrow[]
  matchResults      MatchResult[]
  leaderboardPoints LeaderboardEntry[]

  invitesReceived   TeamInvite[] @relation("Invitee")
  invitesSent       TeamInvite[] @relation("Inviter")
  lobbyReady        RoomLobbyReady[]
}

model CS2Stats {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  kills         Int      @default(0)
  deaths        Int      @default(0)
  kdRatio       Float    @default(0)
  wins          Int      @default(0)
  totalMatches  Int      @default(0)
  winRate       Float    @default(0)
  favoriteMap   String?
  lastFetched   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Dota2Stats {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  mmr           Int      @default(0)
  rankMedal     String?
  wins          Int      @default(0)
  losses        Int      @default(0)
  winRate       Float    @default(0)
  favoriteHero  String?
  lastFetched   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Team {
  id            Int       @id @default(autoincrement())
  name          String
  game          String
  ownerId       Int       @unique
  createdAt     DateTime  @default(now())

  owner         User      @relation("TeamOwner", fields: [ownerId], references: [id])
  members       User[]
  registrations Registration[]
  invites       TeamInvite[]
}

model Tournament {
  id            Int       @id @default(autoincrement())
  title         String
  game          String
  dateTime      DateTime
  entryFee      Float
  maxTeams      Int       @default(8)
  prizePool     Float     @default(0)
  status        String    @default("open")
  format        String    @default("single_elimination")
  bracketData   Json?
  createdAt     DateTime  @default(now())

  registrations Registration[]
  rooms         TournamentRoom[]
  matchResults  MatchResult[]
  escrows       Escrow[]
}

model Registration {
  id            Int        @id @default(autoincrement())
  tournamentId  Int
  teamId        Int
  userId        Int
  paymentStatus String     @default("pending")
  checkedIn     Boolean    @default(false)
  checkedInAt   DateTime?
  placement     Int?
  createdAt     DateTime   @default(now())

  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  team          Team       @relation(fields: [teamId], references: [id])
  user          User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, teamId])
}

model TournamentRoom {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  matchRound   Int
  team1Id      Int
  team2Id      Int
  bracketMatchKey String?
  roomId       String?
  roomPassword String?
  releasedAt   DateTime?
  status       String     @default("pending")
  winnerId     Int?
  createdAt    DateTime   @default(now())

  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  matchResults MatchResult[]
  lobbyReady   RoomLobbyReady[]
}

model MatchResult {
  id            Int        @id @default(autoincrement())
  tournamentId  Int
  roomId        Int
  userId        Int
  steamMatchId  String?
  placement     Int?
  kills         Int?
  screenshotUrl String
  aiConfidence  Float      @default(0)
  extractedData Json?
  status        String     @default("pending")
  refereeNote   String?
  reviewedBy    Int?
  reviewedAt    DateTime?
  createdAt     DateTime   @default(now())

  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  room          TournamentRoom @relation(fields: [roomId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
}

model Escrow {
  id           Int        @id @default(autoincrement())
  userId       Int
  tournamentId Int
  amount       Float
  currency     String     @default("USD")
  status       String     @default("locked")
  paymentRef   String?
  releasedAt   DateTime?
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
}

model LeaderboardEntry {
  id               Int      @id @default(autoincrement())
  userId           Int
  game             String
  points           Int      @default(0)
  tournamentsPlayed Int     @default(0)
  wins             Int      @default(0)
  bestPlacement    Int?
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, game])
}

model TeamInvite {
  id               Int      @id @default(autoincrement())
  teamId           Int
  inviterId        Int
  inviteeId        Int?
  telegramUsername String
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  respondedAt      DateTime?

  team             Team     @relation(fields: [teamId], references: [id])
  inviter          User     @relation("Inviter", fields: [inviterId], references: [id])
  invitee          User?    @relation("Invitee", fields: [inviteeId], references: [id])

  @@unique([teamId, telegramUsername])
}

model RoomLobbyReady {
  id         Int      @id @default(autoincrement())
  roomId     Int
  userId     Int
  readyAt    DateTime @default(now())

  room       TournamentRoom @relation(fields: [roomId], references: [id])
  user       User           @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

